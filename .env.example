# Image
CURIO_IMAGE=mon3trd/curio:latest

# Locale
TZ=Asia/Shanghai

# Web ports
CURIO_PORT=8080
CURIO_EMBY_PROXY_PORT=8097

# Paths
# Windows example: CURIO_DATA_PATH=D:/Curio/data
# Linux example: CURIO_DATA_PATH=/opt/curio/data
# NAS example: CURIO_DATA_PATH=/volume1/docker/curio/data
CURIO_DATA_PATH=./data
CURIO_CONFIG_PATH=./config

# Database and Redis storage
# Use named volumes by default. You can also set host paths for NAS backup.
CURIO_DB_PATH=curio_postgres
CURIO_REDIS_PATH=curio_redis

# Permissions
# Windows/NAS default: 0:0 for widest bind-mount compatibility.
# Linux example: PUID=1000 and PGID=1000.
PUID=0
PGID=0

# Secrets
POSTGRES_PASSWORD=curio
CURIO_PLAY_SECRET=change-me

# Redis cache limit
REDIS_MAXMEMORY=192mb

# Optional integrations
TMDB_API_KEY=
# Host proxy example: NETWORK_PROXY=http://host.docker.internal:7890
NETWORK_PROXY=
